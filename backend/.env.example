# Configuración de base de datos
MONGODB_URI=mongodb://localhost:27017/tio-perro

# Secreto para firmar JWT. Nunca uses un valor por defecto en producción.
JWT_SECRET=tu_secreto_muy_fuerte_aqui

# Orígenes permitidos para CORS, separados por comas.
CORS_ORIGINS=http://localhost:5173

# Habilita la siembra de datos de desarrollo solo cuando sea necesario.
SEED_DB=true
